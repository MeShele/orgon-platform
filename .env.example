# ORGON Environment Variables

# Safina Pay API Configuration
SAFINA_EC_PRIVATE_KEY=your_ec_private_key_here

# Authentication
ORGON_ADMIN_TOKEN=your_admin_token_here

# Telegram Bot Integration (Optional)
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# Get your chat ID from @userinfobot or by sending a message to your bot
TELEGRAM_CHAT_ID=123456789

# ASAGENT Integration (Optional)
# ASAGENT_GATEWAY_WS=ws://127.0.0.1:18789
